{
  "expo": {
    "name": "Visa Atlas",
    "slug": "visa-atlas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "visaatlas",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tirmazilabs.visaatlas",
      "buildNumber": "2",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeEmailAddress",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeName",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeUserID",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ],
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5EFE6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tirmazilabs.visaatlas"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://visa-atlas.vercel.app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 290,
          "resizeMode": "contain",
          "backgroundColor": "#F5EFE6"
        }
      ],
      "expo-web-browser",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Visa Atlas uses Face ID to keep your saved visa records and account secure on this device."
        }
      ],
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Visa Atlas needs access to your photos so you can scan a booking confirmation or document and add it to your trip automatically.",
          "cameraPermission": "Visa Atlas needs camera access so you can scan a booking confirmation or document and add it to your trip automatically.",
          "microphonePermission": false
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Visa Atlas reads your calendar to detect upcoming flights and hotel stays and add them to your trip timeline.",
          "remindersPermission": "Visa Atlas accesses your reminders to surface upcoming visa deadlines and trip tasks."
        }
      ],
      "@maplibre/maplibre-react-native",
      "expo-asset",
      "expo-notifications",
      "expo-localization"
    ],
    "extra": {
      "router": {
        "origin": "https://visa-atlas.vercel.app"
      },
      "eas": {
        "projectId": "a6fbc690-e2f2-4db7-8380-b235ba4cd685"
      }
    }
  }
}
