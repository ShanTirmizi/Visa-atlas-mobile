{
  "expo": {
    "name": "Visa Atlas",
    "slug": "visa-atlas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "visaatlas",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5D9C0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tirmazilabs.visaatlas"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5D9C0"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tirmazilabs.visaatlas"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://visa-atlas.vercel.app"
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ]
  }
}
