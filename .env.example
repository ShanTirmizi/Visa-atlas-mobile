# Visa Atlas — environment variables
# Copy to .env.local and fill in. EXPO_PUBLIC_* vars are embedded in the client bundle.

# ── Convex backend ─────────────────────────────────────────────────────────
CONVEX_DEPLOYMENT=
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_SITE_URL=

# ── Standalone FastAPI AI backend (local dev) ──────────────────────────────
EXPO_PUBLIC_AI_BACKEND_URL=
EXPO_PUBLIC_AI_BACKEND_TOKEN=

# ── PostHog analytics ──────────────────────────────────────────────────────
# Public project API key (phc_...) from us.posthog.com/project/484302 → Settings.
# The SAME key is used server-side: set it on Convex with
#   npx convex env set POSTHOG_API_KEY phc_...
EXPO_PUBLIC_POSTHOG_API_KEY=
# Optional override; defaults to US cloud. EU users: https://eu.i.posthog.com
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
